{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "EMSCore": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=emscore;Username=postgres;Password=postgres;Include Error Detail=true"
  },
  "Mqtt": {
    "BrokerHost": "localhost",
    "BrokerPort": 1883,
    "Username": "",
    "Password": "",
    "UseTls": false,
    "AllowUntrustedCertificates": false,
    "IgnoreCertificateChainErrors": false,
    "ClientId": "EMSCore-Edge",
    "KeepAliveInterval": "00:01:00",
    "MaxPendingMessages": 1000
  },
  "EMS": {
    "SiteId": "site-001",
    "SiteName": "Default Site",
    "EdgeMode": true,
    "DataRetentionDays": 30,
    "BatchSize": 100,
    "FlushIntervalSeconds": 30
  }
}
